{
  "name": "r3f-mind-ar",
  "version": "0.1.5",
  "description": "MindAR image tracking components for React Three Fiber",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "three",
    "threejs",
    "react-three-fiber",
    "r3f",
    "ar",
    "augmented-reality",
    "image-tracking",
    "mindar",
    "mind-ar",
    "webxr",
    "marker"
  ],
  "author": "Chiwon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chiwon/r3f-mind-ar.git"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=9.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.137.0"
  },
  "dependencies": {
    "mind-ar": "^1.2.5"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.5.0",
    "@types/react": "^19.1.2",
    "@types/three": "^0.183.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.183.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
